# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: canonical app URL for server-side code only (OAuth uses window.location.origin in the browser)
# VITE_APP_URL=https://your-app.vercel.app

# Google sign-in: enable in Supabase Dashboard → Authentication → Providers → Google.
# Authentication → URL configuration:
#   Site URL: https://your-app.vercel.app
#   Redirect URLs — required for each origin; if localhost is missing, Supabase
#   sends you to Site URL (production) after Google sign-in:
#     http://localhost:8080/**
#     http://127.0.0.1:8080/**
#     https://your-app.vercel.app/**
# Optional: restrict to specific Gmail accounts (comma-separated)
# VITE_ALLOWED_EMAILS=you@gmail.com,partner@gmail.com

# Same values for server-side code (SSR / server functions)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: recipe import URL cache (bypasses RLS) — never expose to the browser
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI for recipe import (OpenAI-compatible API)
OPENROUTER_API_KEY=your-openrouter-key
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o-mini

# Alternatives: OPENAI_API_KEY or AI_API_KEY with AI_BASE_URL=https://api.openai.com/v1
