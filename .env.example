# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Same values for server-side code (SSR / server functions)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: recipe import URL cache (bypasses RLS) — never expose to the browser
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI for recipe import (OpenAI-compatible API)
OPENROUTER_API_KEY=your-openrouter-key
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o-mini

# Alternatives: OPENAI_API_KEY or AI_API_KEY with AI_BASE_URL=https://api.openai.com/v1
